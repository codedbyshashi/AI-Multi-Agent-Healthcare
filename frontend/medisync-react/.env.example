# Example Environment Variables for React Frontend
# Copy this file to .env.local for local development
# Or set these variables in Vercel dashboard for production

# Backend API URL - Change based on your deployment
VITE_API_URL=https://ai-multi-agent-healthcare.onrender.com

# API Timeout in milliseconds (default: 120000 = 2 minutes)
# Increase this if you're processing large PDFs
VITE_API_TIMEOUT=120000

# Environment name (for logging and debugging)
VITE_ENV=production
